# ---------------------------------------------------------------------------
# Everything below is OPTIONAL: you can configure the container entirely through
# the first-run web UI (http://<host>:8080), which saves your .ovpn + settings
# to the ovpn-data volume. Values set here act as defaults; the web UI overrides
# them once you submit setup.
# ---------------------------------------------------------------------------

# --- Setup web UI ----------------------------------------------------------
# Protect the UI with HTTP Basic Auth. If WEBUI_PASSWORD is empty the UI is
# UNAUTHENTICATED — only expose port 8080 on a trusted network / SSH tunnel.
WEBUI_USER=admin
WEBUI_PASSWORD=
WEBUI_PORT=8080

# --- Headscale / Tailscale (optional; can be set in the web UI) ------------
HEADSCALE_URL=
TS_AUTHKEY=
TS_HOSTNAME=ovpn-exit
TS_EXTRA_ARGS=

# --- OpenVPN (optional; the web UI is the easy path) -----------------------
# If you prefer files over the UI, bind-mount your profile and set OVPN_CONFIG
# to its in-container path. Otherwise upload it via the web UI.
OVPN_CONFIG=
OVPN_AUTH_USER=
OVPN_AUTH_PASS=
OVPN_AUTH_FILE=
